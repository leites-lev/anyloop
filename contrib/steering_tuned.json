{
	"_comment": {
		"1": "Tip/tilt loop with a biquad filter ahead of the PID to keep",
		"2": "loop gain off the ~80 Hz FSM resonance. Pipeline:",
		"3": "  camera -> center_of_mass -> biquad_filter -> pid -> actuator",
		"4": "fs is the measured loop rate (~815 Hz here; check with -p).",
		"5": "Start with the lowpass below. To switch to a surgical notch,",
		"6": "set mode=notch, f0=80, q~2.3 (see the commented block)."
	},
	"pipeline": [
		{
			"uri": "file:/home/fsl/anyloop/build/asi_source.so",
			"params": {
				"camera_name": "ASI290MM",
				"width":       72,
				"height":      72,
				"exposure":    1000,
				"gain":        50,
				"bandwidth":   100
			}
		},
		{
			"_comment": "Send raw frame to watch_steering.jl on port 64730",
			"uri": "anyloop:udp_sink",
			"params": {
				"ip":   "127.0.0.1",
				"port": "64730"
			}
		},
		{
			"uri": "anyloop:center_of_mass",
			"params": {
				"region_height": 72,
				"region_width":  72,
				"threshold":     100
			}
		},
		{
			"_comment": "Send [y, x] CoM vector to watch_steering.jl on port 64731",
			"uri": "anyloop:udp_sink",
			"params": {
				"ip":   "127.0.0.1",
				"port": "64731"
			}
		},
		{
			"_comment": "Send [y, x] CoM vector to watch_error_ts.jl on port 64732",
			"uri": "anyloop:udp_sink",
			"params": {
				"ip":   "127.0.0.1",
				"port": "64732"
			}
		},
		{
			"uri": "anyloop:pid",
			"params": {
				"type": "vector",
				"p": 3,
				"i": 600,
				"d": 0,
				"clamp": 1.0,
				"units": "minmax"
			}
		},
		{
			
			"uri": "anyloop:clamp",
			"params": {
				"type": "vector",
				"min": -1.0,
				"max": 1.0
			}
		},
		
		{
			"_comment" : "Tilt, x axis (-)",
			"uri": "anyloop:piplate_bridge",
			"params": {
				"port": "/dev/ttyACM0",
				"board": 0,
				"channel": 0,
				"index": 1,
				"scale": 0,
				"offset": 2.63
			}
		},
		{
			"_comment" : "Tip, y axis (+)1.9368",
			"uri": "anyloop:piplate_bridge",
			"params": {
				"port": "/dev/ttyACM0",
				"board": 0,
				"channel": 1,
				"index": 0,
				"scale": 0,
				"offset": 0.94
			}
		},
		{
			"uri": "anyloop:file_sink",
			"params": {
				"filename": "error_after_filter.aylp",
				"_note": "log the filtered command stream; move this before the biquad to capture the raw error for an FFT"
			}
		}
	]
}
