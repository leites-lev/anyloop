{
	"pipeline": [
		{      
			"uri": "anyloop:test_source",
			"params": {
				"type": "vector",
				"kind": "sine",
				"size1": 1,
				"offset": 1
				
			}
		},
		{
			"uri": "anyloop:piplate_bridge",
			"params": { 
				"port":    "/dev/ttyACM0",
				"board":   0,    
				"channel": [0,  1,  2, 3],
				"index":   [0,  0,  0,    0],
				"scale":   [0, 0, 0,    0],
				"offset":  [2,  2, 2, 2],
				"_note": "yxY skip_unchanged: a channel is only written when its voltage changes, so constant/idle outputs cost nothing; wait_response=false keeps the serial round-trip off the loop",
				"wait_response": true,
				"skip_unchanged": false
				
			}
		}
	]
}
