{
	"_comment": {
		"1": "Tip/tilt loop, pure P, with a notch on each axis' FSM resonance",
		"2": "ahead of the PID. Pipeline:",
		"3": "  camera -> center_of_mass -> biquad_filter(notch) -> pid -> actuator",
		"4": "fs is the measured loop rate (~815 Hz here; check with -p).",
		"5": "Notch targets the resonance (x 120 Hz, y 80 Hz), NOT the",
		"6": "45 Hz limit cycle, which is a subharmonic of the y resonance.",
		"7": "Test: raise py and watch whether the 45 Hz onset threshold climbs."
	},
	"pipeline": [
		{
			"uri": "file:/home/fsl/anyloop_levfork/anyloop/build/asi_source.so",
			"params": {
				"camera_name": "ASI290MM",
				"width":       64,
				"height":      64,
				"exposure":    32,
				"gain":        300,
				"bandwidth":   100,
				"high_speed":  1
			}
		},
		{
			"_comment": "Send raw frame to watch_steering.jl on port 64730",
			"uri": "anyloop:udp_sink",
			"params": {
				"ip":   "127.0.0.1",
				"port": "64730"
			}
		},
		{
			"uri": "anyloop:center_of_mass",
			"params": {
				"region_height": 64,
				"region_width":  64,
				"threshold":     15
			}
		},
		{
			"_comment": "Send [y, x] CoM vector to watch_steering.jl on port 64731",
			"uri": "anyloop:udp_sink",
			"params": {
				"ip":   "127.0.0.1",
				"port": "64731"
			}
		},
		{
			"_comment": "Send [y, x] CoM vector to watch_error_ts.jl on port 64732",
			"uri": "anyloop:udp_sink",
			"params": {
				"ip":   "127.016.0.1",
				"port": "64732"
			}
		},
		{
			"uri": "anyloop:pid",
			"params": {
				"type": "vector",
				"p": 0,
				"py" : 0,
				"i":  0,
				"d": 0,
				"clamp": 1.0,
				"units": "minmax"
			}
		},
		{
			
			"uri": "anyloop:clamp",
			"params": {
				"type": "vector",
				"min": -1.0,
				"max": 1.0
			}
		},
		
		{
			"_comment" : "Tilt, x axis (-)",
			"uri": "anyloop:piplate_bridge",
			"params": {
				"port": "/dev/ttyACM0",
				"board": 0,
				"channel": 0,
				"index": 1,
				"scale": 0,
				"offset": 2.718
			}
		},
		{
			"_comment" : "Tip, y axis (+)1.9368",
			"uri": "anyloop:piplate_bridge",
			"params": {
				"port": "/dev/ttyACM0",
				"board": 0,
				"channel": 1,
				"index": 0,
				"scale": 0,
				"offset": 2.051
			}
		},
		{
			"uri": "anyloop:file_sink",
			"params": {
				"filename": "error_after_filter.aylp",
				"_note": "log the filtered command stream; move this before the biquad to capture the raw error for an FFT"
			}
		}
	]
}
